{
	"name": "devops-incident-analyzer",
	"private": true,
	"workspaces": {
		"packages": [
			"packages/*",
			"apps/*"
		],
		"catalog": {
			"@langchain/langgraph": "^1.2.2",
			"@langchain/langgraph-checkpoint": "^1.0.0",
			"@langchain/mcp-adapters": "^1.1.3",
			"@langchain/aws": "^0.1.0",
			"@langchain/core": "^1.1.31",
			"@modelcontextprotocol/sdk": "^1.27.1",
			"zod": "^3.24.0",
			"yaml": "^2.6.0",
			"pino": "^9.0.0",
			"marked": "^15.0.0",
			"highlight.js": "^11.10.0",
			"langsmith": "^0.5.8"
		},
		"catalogs": {
			"dev": {
				"@biomejs/biome": "^2.4.6",
				"@types/bun": "^1.3.10",
				"bun-types": "^1.3.10",
				"typescript": "^5.9.3"
			},
			"svelte": {
				"svelte": "^5.0.0",
				"@sveltejs/kit": "^2.0.0",
				"@sveltejs/adapter-auto": "^4.0.0",
				"@sveltejs/vite-plugin-svelte": "^5.0.0",
				"vite": "^6.0.0"
			}
		}
	},
	"scripts": {
		"dev": "bun run --filter '*' dev",
		"test": "bun run --filter '*' test",
		"typecheck": "bun run --filter '*' typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"biome:check": "bunx biome check .",
		"biome:check:write": "bunx biome check --write .",
		"yaml:check": "yamllint -d relaxed agents/ .yamllint.yml"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:dev",
		"typescript": "catalog:dev"
	}
}
