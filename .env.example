# DevOps Incident Analyzer - Environment Configuration
# Copy to .env and fill in values

# === AWS (Bedrock LLM access) ===
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# === LangSmith (tracing + feedback) ===
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=devops-incident-analyzer
LANGSMITH_TRACING=true

# Per-server LangSmith projects (independent from agent orchestration traces)
ELASTIC_LANGSMITH_PROJECT=elastic-mcp-server
KAFKA_LANGSMITH_PROJECT=kafka-mcp-server
COUCHBASE_LANGSMITH_PROJECT=couchbase-mcp-server
KONNECT_LANGSMITH_PROJECT=konnect-mcp-server

# === Elasticsearch MCP (:8080) ===
# Multi-deployment: comma-separated IDs
ELASTIC_DEPLOYMENTS=production,staging
# Per-deployment config (replace PRODUCTION/STAGING with uppercase deployment ID)
ELASTIC_PRODUCTION_URL=https://prod-es.example.com:9200
ELASTIC_PRODUCTION_API_KEY=
ELASTIC_STAGING_URL=https://staging-es.example.com:9200
ELASTIC_STAGING_USERNAME=elastic
ELASTIC_STAGING_PASSWORD=

# === Kafka MCP (:3000) ===
# Provider: local | msk | confluent
KAFKA_PROVIDER=local
KAFKA_BROKERS=localhost:9092
# MSK provider (uncomment for AWS MSK)
# AWS_REGION=eu-west-1
# Confluent provider (uncomment for Confluent Cloud)
# CONFLUENT_API_KEY=
# CONFLUENT_API_SECRET=
# Feature gates
KAFKA_ALLOW_WRITES=false
KAFKA_ALLOW_DESTRUCTIVE=false
SCHEMA_REGISTRY_ENABLED=false
KSQL_ENABLED=false

# === Couchbase Capella MCP (:8082) ===
CB_HOSTNAME=
CB_USERNAME=
CB_PASSWORD=
CB_BUCKET=

# === Kong Konnect MCP (:8083) ===
KONNECT_ACCESS_TOKEN=
KONNECT_REGION=eu

# === Agent Configuration ===
AGENT_LLM_MODEL=claude-sonnet-4-6
AGENT_LLM_HAIKU_MODEL=claude-haiku-4-5
AGENT_LLM_REGION=eu-west-1
AGENT_CHECKPOINTER_TYPE=memory

# === MCP Server URLs (for agent to connect) ===
ELASTIC_MCP_URL=http://localhost:8080
KAFKA_MCP_URL=http://localhost:3000
COUCHBASE_MCP_URL=http://localhost:8082
KONNECT_MCP_URL=http://localhost:8083

# === Server ===
SERVER_PORT=5173
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
