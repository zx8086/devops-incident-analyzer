# DevOps Incident Analyzer - Environment Configuration
# Copy to .env and fill in values

# === gitagent dynamic patterns (all OFF by default; see PR #148 / SIO-843..849) ===
# Live agent memory (EPIC 3): append per-run breadcrumbs + inject durable context.
LIVE_MEMORY_ENABLED=false
# Hash-chain dailylog appends for tamper-evidence (recordkeeping.immutable).
LIVE_MEMORY_IMMUTABLE=false
# PR-based HITL (EPIC 1): open review PRs for durable learnings. Never auto-merges.
MEMORY_PR_ENABLED=false
GITHUB_TOKEN=
MEMORY_PR_REPO=zx8086/devops-incident-analyzer
MEMORY_PR_BASE=main
# Knowledge graph (EPIC 6): embedded LadybugDB (npm lbug) as a Neo4j placeholder.
# lbug is an optional native dep; enable it per packages/knowledge-graph/README.md
# (install + run its install.js once, then migrate/seed).
KNOWLEDGE_GRAPH_ENABLED=false
KNOWLEDGE_GRAPH_PATH=.data/knowledge-graph
EMBEDDINGS_PROVIDER=bedrock
EMBEDDINGS_MODEL=amazon.titan-embed-text-v2:0

# === MCP Transport ===
# Values: stdio | http | both | agentcore
MCP_TRANSPORT=http

# === AWS (Bedrock LLM access) ===
# AWS_REGION drives both Bedrock LLM access and the global default region for the
# AWS MCP estates (per-estate overrides via AWS_ESTATES.region, see below).
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# === LangSmith (tracing + feedback) ===
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=devops-incident-analyzer
LANGSMITH_TRACING=true

# Per-server LangSmith projects (independent from agent orchestration traces)
ELASTIC_LANGSMITH_PROJECT=elastic-mcp-server
KAFKA_LANGSMITH_PROJECT=kafka-mcp-server
COUCHBASE_LANGSMITH_PROJECT=couchbase-mcp-server
KONNECT_LANGSMITH_PROJECT=konnect-mcp-server
GITLAB_LANGSMITH_PROJECT=gitlab-mcp-server
ATLASSIAN_LANGSMITH_PROJECT=atlassian-mcp-server
AWS_LANGSMITH_PROJECT=aws-mcp-server

# === Elasticsearch MCP (:9080) ===
# Multi-deployment mode. Comma-separated deployment IDs. Env key rule:
# uppercase, hyphens -> underscores. Example: eu-cld -> ELASTIC_EU_CLD_URL.
# Each deployment accepts URL + either API_KEY or USERNAME+PASSWORD (or no auth for local).
# Leave ELASTIC_DEPLOYMENTS unset and use ES_URL/ES_API_KEY for legacy single-deployment mode.
ELASTIC_DEPLOYMENTS=eu-cld,us-cld,eu-b2b,ap-cld,gl-cld-reporting,eu-onboarding,eu-cld-monitor,ap-cld-monitor,gl-testing,us-cld-monitor
# Optional: select which deployment is used when no X-Elastic-Deployment header is present.
# Defaults to the first ID in ELASTIC_DEPLOYMENTS.
ELASTIC_DEFAULT_DEPLOYMENT=eu-cld
# Per-deployment credentials (fill in for each ID listed above)
ELASTIC_EU_CLD_URL=
ELASTIC_EU_CLD_API_KEY=
ELASTIC_US_CLD_URL=
ELASTIC_US_CLD_API_KEY=
ELASTIC_EU_B2B_URL=
ELASTIC_EU_B2B_API_KEY=
ELASTIC_AP_CLD_URL=
ELASTIC_AP_CLD_API_KEY=
ELASTIC_GL_CLD_REPORTING_URL=
ELASTIC_GL_CLD_REPORTING_API_KEY=
ELASTIC_EU_ONBOARDING_URL=
ELASTIC_EU_ONBOARDING_API_KEY=
ELASTIC_EU_CLD_MONITOR_URL=
ELASTIC_EU_CLD_MONITOR_API_KEY=
ELASTIC_AP_CLD_MONITOR_URL=
ELASTIC_AP_CLD_MONITOR_API_KEY=
ELASTIC_GL_TESTING_URL=
ELASTIC_GL_TESTING_API_KEY=
ELASTIC_US_CLD_MONITOR_URL=
ELASTIC_US_CLD_MONITOR_API_KEY=
# Legacy single-deployment fallback (used when ELASTIC_DEPLOYMENTS is unset)
# ES_URL=https://es.example.com:9200
# ES_API_KEY=
# ES_USERNAME=elastic
# ES_PASSWORD=

# Elastic Cloud Deployment + Billing API (api.elastic-cloud.com).
# Org-scoped; distinct from per-deployment cluster API keys above. Generate at
# Elastic Cloud console -> User profile -> API keys. When EC_API_KEY is unset
# the 7 elasticsearch_cloud_* / elasticsearch_billing_* tools simply do not
# register and the server boots normally for self-hosted ES users.
EC_API_KEY=
# Optional: defaults to https://api.elastic-cloud.com.
# EC_API_ENDPOINT=https://api.elastic-cloud.com
# Optional: when set, billing tools fall back to this org_id when no org_id arg
# is passed. Without it, every billing tool call must include org_id explicitly.
EC_DEFAULT_ORG_ID=
# Optional tuning. Defaults: 30000ms timeout, 3 retries on 5xx with backoff.
# EC_REQUEST_TIMEOUT=30000
# EC_MAX_RETRIES=3

# === Kafka MCP (:9081) ===
# Provider: local | msk | confluent
KAFKA_PROVIDER=local
KAFKA_BROKERS=localhost:9092
# MSK provider (uncomment for AWS MSK; AWS_REGION already set above)
# AWS_REGION=eu-central-1
# Confluent provider (uncomment for Confluent Cloud)
# CONFLUENT_API_KEY=
# CONFLUENT_API_SECRET=
# Feature gates
KAFKA_ALLOW_WRITES=false
KAFKA_ALLOW_DESTRUCTIVE=false
SCHEMA_REGISTRY_ENABLED=false
KSQL_ENABLED=false

# === Couchbase Capella MCP (:9082) ===
CB_HOSTNAME=
CB_USERNAME=
CB_PASSWORD=
CB_BUCKET=

# === Kong Konnect MCP (:9083) ===
# REQUIRED: konnect's config schema rejects an empty token (Zod .min(1)), so the
# server fails validation on boot and never binds :9083 -- the agent then logs
# "konnect-mcp ... fetch failed" even though the bun --hot process stays alive.
# Set a real token to bring konnect online.
KONNECT_ACCESS_TOKEN=
# Allowed: us|eu|au|me|in -- must match your Konnect org's geo (schema default: us)
KONNECT_REGION=eu

# === Agent Configuration ===
AGENT_LLM_MODEL=claude-sonnet-4-6
AGENT_LLM_HAIKU_MODEL=claude-haiku-4-5
# NOTE: currently unused — the Bedrock LLM region resolves from AWS_REGION
# (model-factory.ts). Kept here for documentation; set AWS_REGION instead.
AGENT_LLM_REGION=eu-central-1
AGENT_CHECKPOINTER_TYPE=memory

# === MCP Server URLs (for agent to connect) ===
ELASTIC_MCP_URL=http://localhost:9080
KAFKA_MCP_URL=http://localhost:9081
COUCHBASE_MCP_URL=http://localhost:9082
KONNECT_MCP_URL=http://localhost:9083
GITLAB_MCP_URL=http://localhost:9084
AWS_MCP_URL=http://localhost:3001
# Elastic IaC maker server (terraform + git + gitlab + elastic reads). This is the
# agent-side dial URL -- the bridge only connects to elastic-iac when it is set
# (apps/web agent.ts). When unset, the agent never dials it and the elastic-iac
# bootstrap logs "not connected" (this is NOT a fetch failure). The server itself
# boots with no secrets; the creds in the block below are optional.
ELASTIC_IAC_MCP_URL=http://localhost:9086

# === Elastic IaC MCP (:9086) ===
# ELASTIC_IAC_MCP_PORT=9086
# ELASTIC_IAC_GITLAB_PROJECT_ID=71488350
# ELASTIC_IAC_WORKSPACE_DIR=/tmp/elastic-iac-workspace
# TERRAFORM_BIN=terraform
# ELASTIC_IAC_TASK_BIN=task   # task runner for read-only helper verbs (iac_status/list/output/state-list)
# GITLAB_BASE_URL=https://gitlab.com
# ELASTIC_CLOUD_BASE_URL=https://api.elastic-cloud.com
# Credentials are optional; tools degrade with a clear message when absent:
# GITLAB_PERSONAL_ACCESS_TOKEN, EC_API_KEY
#
# --- GitOps proposer target (SIO-873, migrated SIO-891) ---
# The agent edits JSON config + opens an MR via the GitLab REST API; CI owns
# plan/apply. The REPO TARGET (base URL + project) is resolved by the elastic-iac
# MCP server. Since SIO-891 it lives on the SAME instance as GITLAB_BASE_URL above
# (gitlab.com); kept as separate vars so the target can diverge again. It still uses
# its own token var below (ELASTIC_IAC_GITLAB_TOKEN).
# ELASTIC_IAC_GITLAB_BASE_URL=https://gitlab.com
# ELASTIC_IAC_GITLAB_PROJECT=pvhcorp/dhco/observability/observability-elastic-iac
ELASTIC_IAC_GITLAB_TOKEN=        # required for branch/commit/MR on the GitOps repo
# The per-deployment JSON path is resolved AGENT-side (it knows the cluster) and
# passed to the MCP tools. ${cluster} is the deployment name.
# ELASTIC_IAC_DEPLOYMENT_JSON_TEMPLATE=environments/_deployments/${cluster}.json
# SIO-880: agent-side path template for ILM lifecycle-policy JSON (${cluster}/${policy} literal placeholders)
# ELASTIC_IAC_ILM_POLICY_TEMPLATE=environments/${cluster}/lifecycle-policies/${policy}.json

# === AgentCore Runtime config (per-server) ===
# Each MCP server that runs against an AgentCore-deployed runtime needs its
# own <PREFIX>_AGENTCORE_* block. Required: RUNTIME_ARN, REGION, PROXY_PORT.
# Optional: QUALIFIER, SERVER_NAME, AWS_ACCESS_KEY_ID/_SECRET_ACCESS_KEY,
# AWS_PROFILE (for AWS CLI profile fallback).
#
# Migration note: the generic AGENTCORE_* env vars are no longer
# honored. If your local .env has them, rename per the block below.

# Kafka MCP via AgentCore (uncomment + fill in when deploying):
# KAFKA_AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:eu-central-1:<account>:runtime/kafka_mcp_server-XXXXX
# KAFKA_AGENTCORE_REGION=eu-central-1
# KAFKA_AGENTCORE_PROXY_PORT=3000
# KAFKA_AGENTCORE_AWS_PROFILE=default
# # OR explicit creds:
# # KAFKA_AGENTCORE_AWS_ACCESS_KEY_ID=
# # KAFKA_AGENTCORE_AWS_SECRET_ACCESS_KEY=

# AWS MCP via AgentCore (uncomment + fill in when deploying):
# AWS_AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:eu-central-1:<account>:runtime/aws_mcp_server-XXXXX
# AWS_AGENTCORE_REGION=eu-central-1
# AWS_AGENTCORE_PROXY_PORT=3001
# AWS_AGENTCORE_AWS_PROFILE=default
# # OR explicit creds:
# # AWS_AGENTCORE_AWS_ACCESS_KEY_ID=
# # AWS_AGENTCORE_AWS_SECRET_ACCESS_KEY=

# === AWS estates (multi-estate support) ===
# JSON map describing every target AWS account the runtime can query. One
# AgentCore runtime serves N estates; the awsEstateRouter node picks per turn.
# Each value is {assumedRoleArn, externalId}. Estate IDs must be lowercase
# alphanumeric with optional hyphens.
#
# SIO-837: the AgentCore host account (the account the runtime itself runs in) is
# just another estate. It assumes a DevOpsAgentReadOnly role in its OWN account
# (same-account AssumeRole) -- identical {assumedRoleArn, externalId} shape, same
# trust policy + ExternalId as every other estate. No special host-credential path.
#
# The runtime calls sts:AssumeRole per-estate at boot. Failures do NOT block
# startup (4-pillar pattern) -- the runtime always boots and reports per-estate
# health via the aws_list_estates MCP tool. Tool calls against a degraded estate
# surface AccessDenied at call time.
#
# Migration from the legacy singletons: AWS_ASSUMED_ROLE_ARN and AWS_EXTERNAL_ID
# are removed. Move them into AWS_ESTATES like the single-estate example below.
#
# Single estate (one-line minified JSON to keep shell quoting sane):
# AWS_ESTATES='{"prod":{"assumedRoleArn":"arn:aws:iam::<account>:role/DevOpsAgentReadOnly","externalId":"<external-id>"}}'
#
# SIO-832: Optional per-estate `region` override. When absent, AWS_REGION is used.
# Required for estates whose workloads live outside the default region:
# AWS_ESTATES='{"prod-eu-west":{"assumedRoleArn":"arn:aws:iam::<account>:role/DevOpsAgentReadOnly","externalId":"<external-id>","region":"eu-west-1"}}'
#
# Multi-estate (6 estates, all values are placeholders -- never commit real account IDs or ExternalIds):
# AWS_ESTATES='{"estate-1":{"assumedRoleArn":"arn:aws:iam::<ACCOUNT_ID_1>:role/DevOpsAgentReadOnly","externalId":"<EXTERNAL_ID_PLACEHOLDER>"},"estate-2":{"assumedRoleArn":"arn:aws:iam::<ACCOUNT_ID_2>:role/DevOpsAgentReadOnly","externalId":"<EXTERNAL_ID_PLACEHOLDER>"},"estate-3":{"assumedRoleArn":"arn:aws:iam::<ACCOUNT_ID_3>:role/DevOpsAgentReadOnly","externalId":"<EXTERNAL_ID_PLACEHOLDER>"},"estate-4":{"assumedRoleArn":"arn:aws:iam::<ACCOUNT_ID_4>:role/DevOpsAgentReadOnly","externalId":"<EXTERNAL_ID_PLACEHOLDER>"},"estate-5":{"assumedRoleArn":"arn:aws:iam::<ACCOUNT_ID_5>:role/DevOpsAgentReadOnly","externalId":"<EXTERNAL_ID_PLACEHOLDER>"},"estate-6":{"assumedRoleArn":"arn:aws:iam::<ACCOUNT_ID_6>:role/DevOpsAgentReadOnly","externalId":"<EXTERNAL_ID_PLACEHOLDER>"}}'

# === AgentCore execution role ===
# REQUIRED when running scripts/agentcore/deploy.sh with MCP_SERVER=aws.
# Pre-existing IAM role in the AgentCore account (e.g. <AGENTCORE_ACCOUNT_ID>) carrying
# the inline DevOpsAgentCoreAssumePolicy. The deploy script does NOT create
# this role; it consumes the ARN and pre-flights existence with iam:GetRole.
# Provisioning the role + its inline policy is documented in
# docs/runbooks/aws-estate-onboarding.md.
# EXECUTION_ROLE_ARN=arn:aws:iam::<AGENTCORE_ACCOUNT_ID>:role/DevOpsAgentCoreRole

# === GitLab Integration (gitlab-agent data source) ===
GITLAB_INSTANCE_URL=https://gitlab.com
GITLAB_PERSONAL_ACCESS_TOKEN=
GITLAB_DEFAULT_PROJECT_ID=
# Local port the GitLab MCP proxy listens on for the OAuth redirect during interactive
# authorization. Must match the port registered with GitLab DCR (default 9184).
GITLAB_OAUTH_CALLBACK_PORT=9184

# === MCP OAuth (applies to gitlab + atlassian MCP proxies) ===
# Default "true": the proxy throws OAuthRequiresInteractiveAuthError instead of
# popping a browser, which the agent classifies as a non-retryable auth error.
# This requires a one-time interactive seed BEFORE running headless:
#   bun run oauth:seed:gitlab
#   bun run oauth:seed:atlassian
# Tokens are persisted under ~/.mcp-auth/{gitlab,atlassian}/ and refreshed
# automatically. Set to "" (empty) only when you actively want interactive
# OAuth in `bun run dev` -- otherwise leave as-is.
#
# Diagnosing "token already exists but I can't login": run the read-only doctor
# (no browser, prints scope/expiry/live-status and whether the failure is OAuth
# vs the separate GITLAB_PERSONAL_ACCESS_TOKEN):
#   bun run oauth:doctor:gitlab
#   bun run oauth:doctor:atlassian
# To forcibly replace a token you suspect is stale (re-runs the browser flow):
#   bun run oauth:seed:gitlab -- --force
MCP_OAUTH_HEADLESS=true

# === Sub-agent tool-result cap ===
# Defaults to 65536 when unset (default-on after pass-4 eval).
# Set "0" to disable. Set to another positive integer to override the cap. The
# truncator JSON-aware-trims each MCP tool result before it re-enters the ReAct
# loop; applies per-call, not cumulatively, so the model still sees fresh
# observations across iterations. Truncation logs subagent.tool_result_truncated
# with the chosen strategy (json-hits, json-array, markdown-json, etc.).
SUBAGENT_TOOL_RESULT_CAP_BYTES=

# === Slack Integration (notify-slack action tool) ===
# Bot token from your Slack app (requires chat:write, files:write scopes)
SLACK_BOT_TOKEN=
# Default channel for incident notifications (used when agent doesn't specify one)
SLACK_DEFAULT_CHANNEL=#incidents

# === Linear Ticket Integration (create-ticket action tool) ===
# API key from Linear Settings > API > Personal API keys
LINEAR_API_KEY=
# Team ID: Siobytes
LINEAR_TEAM_ID=e5922f3c-e630-4633-82b3-5b675ad715e0
# Project ID: DevOps Incidents (separate from development issues)
LINEAR_PROJECT_ID=e515aee7-6a2d-4b88-b1ac-20fe49e4c726

# === Server ===
SERVER_PORT=5173
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# === Atlassian MCP (:9085) ===
# ATLASSIAN_MCP_URL is the local proxy the agent connects to (matches
# every other datasource's URL convention). ATLASSIAN_UPSTREAM_MCP_URL is the
# Atlassian Cloud Rovo endpoint the local proxy forwards to.
ATLASSIAN_MCP_URL=http://localhost:9085
ATLASSIAN_UPSTREAM_MCP_URL=https://mcp.atlassian.com/v1/mcp
ATLASSIAN_SITE_NAME=
ATLASSIAN_READ_ONLY=true
ATLASSIAN_INCIDENT_PROJECTS=INC,OPS
ATLASSIAN_OAUTH_CALLBACK_PORT=9185
ATLASSIAN_TIMEOUT=30000
ATLASSIAN_MCP_PORT=9085
