# Dockerfile.agentcore
#
# Container image for deploying the Kafka MCP server to AgentCore Runtime.
#
# AgentCore Runtime contract:
#   - Container must listen on port 8000
#   - GET /ping must return 200 (health check)
#   - POST /mcp handles MCP protocol (stateless streamable-HTTP)
#
# Build:
#   docker build -f Dockerfile.agentcore -t kafka-mcp-agentcore .
#
# Test locally:
#   docker run --rm -p 8000:8000 \
#     -e KAFKA_PROVIDER=msk \
#     -e MSK_CLUSTER_ARN=arn:aws:kafka:eu-west-1:123456789:cluster/... \
#     -e AWS_REGION=eu-west-1 \
#     kafka-mcp-agentcore

# ── Stage 1: Install dependencies ──
FROM oven/bun:1-alpine AS deps
WORKDIR /app

# Copy workspace root files needed for resolution
COPY package.json bunfig.toml ./
COPY packages/shared/package.json packages/shared/
COPY packages/mcp-server-kafka/package.json packages/mcp-server-kafka/

RUN bun install --frozen-lockfile --production

# ── Stage 2: Copy source ──
FROM oven/bun:1-alpine AS runtime
WORKDIR /app

# Copy installed dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=deps /app/packages/mcp-server-kafka/node_modules ./packages/mcp-server-kafka/node_modules

# Copy source code
COPY packages/shared/ packages/shared/
COPY packages/mcp-server-kafka/ packages/mcp-server-kafka/

# AgentCore Runtime expects port 8000
EXPOSE 8000

# Health check — AgentCore also checks /ping but this helps Docker
HEALTHCHECK --interval=10s --timeout=5s --start-period=5s --retries=3 \
  CMD wget -q --spider http://localhost:8000/ping || exit 1

# Use the AgentCore-specific entrypoint
CMD ["bun", "run", "packages/mcp-server-kafka/src/agentcore-entrypoint.ts"]
