{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "TrustAgentCoreInSharedServices",
			"Effect": "Allow",
			"Principal": {
				"AWS": "arn:aws:iam::399987695868:role/DevOpsAgentCoreRole"
			},
			"Action": "sts:AssumeRole",
			"Condition": {
				"StringEquals": {
					"sts:ExternalId": "devops-agent-prod-access"
				}
			}
		}
	]
}
